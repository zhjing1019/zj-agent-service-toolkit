# 复制本文件为 .env 后填写真实值（勿将 .env 提交到 Git）
# cp .env.example .env

# =============================================================================
# 服务（可选）
# =============================================================================
# SERVICE_NAME=zj-agent
# HOST=0.0.0.0
# PORT=8000

# =============================================================================
# 大模型：默认走 DeepSeek（与 langchain_openai ChatOpenAI 兼容）
# =============================================================================
DEFAULT_LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 若 DEFAULT_LLM_PROVIDER=openai 时使用
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-3.5-turbo

# =============================================================================
# 数据库
# =============================================================================
SQLITE_PATH=./data/agent.db

# =============================================================================
# 安全与工具
# =============================================================================
SAFE_MODE=True
DEFAULT_FILE_NAME=output.txt
MAX_MEMORY=10

# =============================================================================
# RAG 知识库与向量
# =============================================================================
RAG_KNOWLEDGE_DIR=./knowledge
CHROMA_DB_DIR=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# HuggingFace 镜像与下载（国内可配 HF_ENDPOINT，例如 https://hf-mirror.com）
# HF_ENDPOINT=
HF_HUB_DOWNLOAD_TIMEOUT=300
# HUGGINGFACE_HUB_CACHE=

RAG_TOP_K=3
RAG_MAX_CONTEXT_LEN=2000
CHUNK_SIZE=512
CHUNK_OVERLAP=60

RAG_COREFERENCE_ENABLE=true
RAG_COREFERENCE_MAX_MESSAGES=12

HYBRID_TOP_K=3
BM25_TOP_K=3
RERANK_ENABLE=false
