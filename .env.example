# 复制本文件为 .env 后填写真实值（勿将 .env 提交到 Git）
# cp .env.example .env

# =============================================================================
# 服务（可选）
# =============================================================================
# SERVICE_NAME=zj-agent
# HOST=0.0.0.0
# PORT=8000

# =============================================================================
# 大模型：默认走 DeepSeek（与 langchain_openai ChatOpenAI 兼容）
# =============================================================================
DEFAULT_LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 若 DEFAULT_LLM_PROVIDER=openai 时使用
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-3.5-turbo

# =============================================================================
# LLM 重试与降级（主模型多次失败后尝试备用提供商，再失败则返回「系统降级」人工接管提示）
# =============================================================================
# 主模型调用最大尝试次数（每次失败且为可重试错误时会退避等待后重试）
# LLM_RETRY_MAX=3
# LLM_RETRY_BACKOFF_SEC=0.6
# 备用提供商：与 DEFAULT_LLM_PROVIDER 不同且已配置对应 API Key 时生效，例如主用 deepseek 时填 openai
# LLM_FALLBACK_PROVIDER=
# 判定「降级回复」的前缀（规划/汇总跳过二次 LLM 时依赖此前缀）
# LLM_FAILURE_DEGRADE_PREFIX=【系统降级】
# LLM_FAILURE_HANDOFF_MESSAGE=【系统降级】大模型多次调用仍失败（网络超时/额度或服务异常）。请稍后重试或联系人工处理。
#
# 工具：在 TOOL_REGISTRY 中的名称，逗号分隔，视为「核心」并多轮重试；其余工具按 TOOL_RETRY_OTHER
# TOOL_CORE_NAMES=add,subtract,multiply,divide,get_now_time,get_now_date
# TOOL_RETRY_CORE=3
# TOOL_RETRY_OTHER=1
# TOOL_FAILURE_HANDOFF_MESSAGE=【系统降级】工具多次执行仍失败。请检查参数或联系人工处理。

# =============================================================================
# 任务与工具墙钟超时（<=0 表示不限制；超时后调用方不再等待，日志打【告警】）
# =============================================================================
# 整图 invoke（POST /chat、POST /task/resume）与 SSE（图前置 + 流式汇总共享同一总预算，默认 600s）
# AGENT_GRAPH_TIMEOUT_SEC=600
# 单次 TOOL_REGISTRY 同步调用（每次重试各算一次）
# TOOL_CALL_TIMEOUT_SEC=30

# =============================================================================
# 数据库
# =============================================================================
SQLITE_PATH=./data/agent.db
LANGGRAPH_CHECKPOINT_SQLITE_PATH=./data/langgraph_checkpoints.sqlite

# =============================================================================
# 安全与工具
# =============================================================================
SAFE_MODE=True
DEFAULT_FILE_NAME=output.txt
MAX_MEMORY=10

# =============================================================================
# RAG 知识库与向量
# =============================================================================
RAG_KNOWLEDGE_DIR=./knowledge
CHROMA_DB_DIR=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# HuggingFace 镜像与下载（国内可配 HF_ENDPOINT，例如 https://hf-mirror.com）
# HF_ENDPOINT=
HF_HUB_DOWNLOAD_TIMEOUT=300
# HUGGINGFACE_HUB_CACHE=

RAG_TOP_K=3
RAG_MAX_CONTEXT_LEN=2000
CHUNK_SIZE=512
CHUNK_OVERLAP=60

RAG_COREFERENCE_ENABLE=true
RAG_COREFERENCE_MAX_MESSAGES=12

HYBRID_TOP_K=3
BM25_TOP_K=3
RERANK_ENABLE=false
